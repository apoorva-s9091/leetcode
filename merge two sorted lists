class Solution:
    def mergeTwoLists(self, list1: Optional[ListNode], list2: Optional[ListNode]) -> Optional[ListNode]:
        vals=[]
        curr=list1
        while curr:
            vals.append(curr.val)
            curr=curr.next

        curr=list2
        while curr:
            vals.append(curr.val)
            curr=curr.next

        vals.sort()
        dummy=ListNode(0)
        curr=dummy
        for val in vals:
            curr.next=ListNode(val)
            curr=curr.next
        return dummy.next
