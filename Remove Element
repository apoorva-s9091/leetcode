class Solution:
    def removeElement(self, nums: List[int], val: int) -> int:
        if not nums:
            return 0

        s=0; f=len(nums)-1
        while(s<=f):
            if nums[s] == val:
                nums[s], nums[f] = nums[f], nums[s]
                f -= 1
            else:
                s += 1
            
        return s
